SELECT first_name, last_name FROM people;
SELECT * FROM people;
SELECT team, shirt_or_hat, first_name, last_name
FROM people
WHERE state_code=&quot;CO&quot;
ORDER BY team, shirt_or_hat, first_name DESC;
SELECT people.team, states.region, COUNT(people.team)
FROM states JOIN people ON states.state_abbrev=people.state_code
GROUP BY states.region, people.team;
SELECT 1/3;
SELECT 1/3.0;
SELECT first_name, quiz_points
FROM people
WHERE quiz_points&gt;=70
ORDER BY quiz_points;
SELECT * FROM people;
SELECT COUNT(*) FROM people
WHERE state_code=&quot;CA&quot; AND quiz_points=70;
SELECT first_name, last_name, state_code, quiz_points FROM people
WHERE quiz_points&gt;=70 AND state_code=&quot;CA&quot;
ORDER BY quiz_points ASC;



