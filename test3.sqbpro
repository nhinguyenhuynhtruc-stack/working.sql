 value="39"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="states" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="119"/><column index="2" value="85"/><column index="3" value="79"/><column index="4" value="151"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT * FROM people;
INSERT INTO people (
id_number,
first_name,
last_name,
city,
state_code,
shirt_or_hat,
quiz_points,
team,
signup,
age,
company
)
VALUES (
1001,
&quot;Nhi&quot;,
&quot;Nguyen&quot;,
&quot;Buford&quot;,
&quot;GA&quot;,
&quot;hat&quot;,
74,
&quot;Angry Birds&quot;,
2026-03-06,
34,
&quot;Flywire&quot;
)
;
SELECT * FROM states 
ORDER BY state_name DESC;
SELECT * FROM people
WHERE first_name IS NULL OR
last_name IS NULL OR
city IS NULL OR 
state_code IS NULL OR
shirt_or_hat IS NULL OR
quiz_points IS NULL OR
team IS NULL OR
signup IS NULL OR
age IS NULL OR
company IS NULL;
SELECT id_number,
first_name,
last_name,
state_code,
shirt_or_hat,
quiz_points,
team,
company
FROM people
WHERE company IS NOT NULL;
SELECT *,
strftime('%m', signup)AS MonthNumber
FROM people
WHERE company IS NOT NULL;
SELECT * ,
strftime('%m', signup) AS MonthNumber,
CASE strftime('%m', signup)
    WHEN '01' THEN 'January'
    WHEN '02' THEN 'February'
    WHEN '03' THEN 'March'
    WHEN '04' THEN 'April'
    WHEN '05' THEN 'May'
    WHEN '06' THEN 'June'
    WHEN '07' THEN 'July'
    WHEN '08' THEN 'August'
    WHEN '09' THEN 'September'
    WHEN '10' THEN 'October'
    WHEN '11' THEN 'November'
    WHEN '12' THEN 'December'
END AS MonthName
FROM people
WHERE company IS NOT NULL;
</sql><current_tab id="0"/></tab_sql></sqlb_project>
